# Radio Seneca — environment variables
# Copy to .env in repo root for docker-compose, or to apps/web/.env for local dev

# AzuraCast (broadcast server)
VITE_AZURACAST_URL=https://demo.azuracast.com
VITE_STATION_ID=1

# Strapi CMS
VITE_STRAPI_URL=http://localhost:1337

# Docker / production nginx upstreams (used in infra/nginx.conf via envsubst)
AZURACAST_UPSTREAM=https://your-azuracast.example.com
STRAPI_UPSTREAM=http://strapi:1337

# PostgreSQL (docker-compose)
POSTGRES_DB=strapi
POSTGRES_USER=strapi
POSTGRES_PASSWORD=change-me-in-production

# Strapi secrets (generate unique values for production)
APP_KEYS=changeMe1,changeMe2
API_TOKEN_SALT=changeMe
ADMIN_JWT_SECRET=changeMe
TRANSFER_TOKEN_SALT=changeMe
JWT_SECRET=changeMe
